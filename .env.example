# --- Neon Postgres ---
# Copy this file to ".env" and paste your Neon connection string below.
# Get it from the Neon dashboard (use the "pooled" connection string). Keep ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Admin login (used on /admin.html) ---
ADMIN_USER=admin
ADMIN_PASS=change-this-password

# --- Auth token signing secret (any long random string) ---
JWT_SECRET=replace-with-a-long-random-secret-string

# --- Server port ---
PORT=5000